# Copy to frontend/.env.local
# Same-origin API (backend dev or production on one host)
VITE_API_URL=

# Vercel → Project → Settings → Environment Variables (Production):
# VITE_API_URL=https://cv-pro-back.onrender.com
# Render backend → CORS_ORIGIN=https://cv-pro-back.vercel.app

# Standalone: npm run dev:frontend — proxy /api to backend (match backend/.env PORT)
VITE_API_PROXY_TARGET=http://localhost:3001
