PORT=3000
NODE_ENV=development
# Comma-separated frontend URLs (required in production for cross-origin SPA)
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
JSON_LIMIT=2mb
CV_TEXT_MAX_LENGTH=40000
CACHE_TTL_MS=300000
SESSION_TTL_MS=604800000
AUTH_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
OPENAI_TIMEOUT_MS=30000
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=2200
OPENAI_API_KEY=your-openai-api-key-here
DATABASE_URL=postgresql://postgres:password@localhost:5432/cv_ai_pro
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_OUTPUT_TOKENS=4000
